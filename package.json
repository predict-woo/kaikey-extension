{
  "name": "kaikey",
  "displayName": "Kaikey",
  "version": "0.1.0",
  "description": "Kaikey 2FA helper extension",
  "author": "andyye",
  "scripts": {
    "dev": "plasmo dev",
    "dev:firefox": "plasmo dev --target=firefox-mv3",
    "build": "plasmo build",
    "build:firefox": "plasmo build --target=firefox-mv3",
    "package": "plasmo package",
    "package:firefox": "plasmo package --target=firefox-mv3"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.13.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.460.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.20",
    "postcss": "8.4.33",
    "tailwindcss": "3.4.1",
    "typescript": "5.3.3"
  },
  "manifest": {
    "name": "Kaikey",
    "host_permissions": [
      "https://sso.kaist.ac.kr/*",
      "https://klms.kaist.ac.kr/*"
    ],
    "permissions": [
      "storage",
      "activeTab",
      "scripting"
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "kaikey@local",
        "strict_min_version": "128.0"
      }
    }
  }
}
